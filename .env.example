# ================================================
# WCAG Scanner — Environment Variables
# Copy this file to .env.local and fill in values.
# See SETUP.md §5 for full documentation.
# ================================================

# ── Supabase (required) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Dodo Payments (required for billing) ──
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dodo product IDs — create these in Dodo dashboard BEFORE deploy
DODO_STARTER_PRODUCT_ID=
DODO_STARTER_ANNUAL_PRODUCT_ID=
DODO_GROWTH_PRODUCT_ID=
DODO_GROWTH_ANNUAL_PRODUCT_ID=
DODO_ENTERPRISE_PRODUCT_ID=
DODO_ENTERPRISE_ANNUAL_PRODUCT_ID=

# ── Email (Resend) ──
RESEND_API_KEY=

# ── AI ──
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# ── Cron / GitHub Actions ──
CRON_SECRET=

# ── GitHub Actions → hosted API (multiscan worker) ──
SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY is shared with §Supabase section above

# ── GitHub dispatches from multiscan route (worker trigger) ──
GITHUB_PAT=
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
