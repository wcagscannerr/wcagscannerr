# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Dodo Payments Configuration
DODO_PAYMENTS_API_KEY=your_dodo_live_api_key
DODO_PAYMENTS_ENVIRONMENT=live_mode
DODO_PAYMENTS_WEBHOOK_KEY=your_dodo_webhook_signing_key
DODO_PRO_PRODUCT_ID=your_dodo_pro_product_id
DODO_PRO_ANNUAL_PRODUCT_ID=your_dodo_proo_annual_product_id
DODO_AGENCY_PRODUCT_ID=your_dodo_agency_product_id
DODO_AGENCY_ANNUAL_PRODUCT_ID=your_dodo_agency_annual_product_id

# Resend Email
RESEND_API_KEY=re_xxx
CONTACT_EMAIL=support@wcagscannerr.com

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron Secret (for Vercel Cron Jobs)
CRON_SECRET=your_cron_secret

# GitHub Personal Access Token (for Multi-Page Scanner)
# IMPORTANT: Must be a PAT, NOT the default GITHUB_TOKEN
# Create at: https://github.com/settings/tokens
# Required scopes: repo (full control)
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Repository (for Multi-Page Scanner workflow dispatch)
# These must match your GitHub repo where the multiscan.yml workflow lives
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=wcagscannerr

# DeepSeek API (for AI features)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ═══════════════════════════════════════════════════════════════
# GitHub Actions Secrets (for Multi-Page Scanner)
# Add these in: GitHub repo → Settings → Secrets and variables → Actions
# ═══════════════════════════════════════════════════════════════
# Same as NEXT_PUBLIC_SUPABASE_URL but use the full URL
SUPABASE_URL=https://your-project.supabase.co
# Same as SUPABASE_SERVICE_ROLE_KEY (reuse the value)
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Same as NEXT_PUBLIC_APP_URL (use your production URL)
# NEXT_PUBLIC_APP_URL=https://www.wcagscannerr.com
# Same as CRON_SECRET (reuse the value)
# CRON_SECRET=your_cron_secret
# Same as RESEND_API_KEY (reuse the value)
# RESEND_API_KEY=re_xxx